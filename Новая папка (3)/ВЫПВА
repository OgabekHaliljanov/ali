            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="flex items-center mb-4 md:mb-0">
                    <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mr-3">
                        <span class="text-white font-heading font-bold text-xl">A</span>
                    </div>
                    <h1 class="text-2xl md:text-3xl font-heading font-bold text-primary" data-lang-key="siteTitle">ALI-CLUB</h1>
                </div>
                
                <div class="flex flex-wrap justify-center gap-4 md:gap-8">
                    <a href="#home" class="nav-link text-gray-700 hover:text-accent font-medium transition-colors duration-300" data-lang-key="navHome">Главная</a>
                    <a href="#champions" class="nav-link text-gray-700 hover:text-accent font-medium transition-colors duration-300" data-lang-key="navChampions">Чемпионы</a>
                    <a href="#trainers" class="nav-link text-gray-700 hover:text-accent font-medium transition-colors duration-300" data-lang-key="navTrainers">Тренеры</a>
                    <a href="#application" class="nav-link text-gray-700 hover:text-accent font-medium transition-colors duration-300" data-lang-key="navApplication">Записаться</a>
                    <a href="#videos" class="nav-link text-gray-700 hover:text-accent font-medium transition-colors duration-300" data-lang-key="navVideos">Видео</a>
