                    <div class="flex flex-wrap justify-center gap-4">
                        <a href="#application" class="bg-accent hover:bg-accent-dark text-white font-bold py-3 px-8 rounded-full transition-all duration-300 btn-hover" data-lang-key="applyNowBtn">Записаться сейчас</a>
                        <button id="showAchievementsBtn" class="bg-transparent border-2 border-white hover:bg-white hover:text-primary text-white font-bold py-3 px-8 rounded-full transition-all duration-300 btn-hover flex items-center">
