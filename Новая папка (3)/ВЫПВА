<!DOCTYPE html>
<html lang="ru">
<head>
    <base target="_self">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ALI-CLUB - Спортивный клуб</title>
    <meta name="description" content="ALI-CLUB - современный спортивный клуб с профессиональными тренерами и чемпионами. Запишись на тренировки по различным видам единоборств.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#1a365d",
                        secondary: "#2d3748",
                        accent: "#e53e3e",
                        "accent-light": "#fc8181",
                        "accent-dark": "#c53030",
                        gold: "#d69e2e",
                        silver: "#a0aec0",
                        bronze: "#ed8936",
                        success: "#38a169",
                        "success-light": "#c6f6d5"
                    },
                    fontFamily: {
                        'heading': ['Montserrat', 'sans-serif'],
                        'body': ['Roboto', 'sans-serif']
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'slide-up': 'slideUp 0.3s ease-out',
                        'pulse-slow': 'pulse 3s infinite'
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' }
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' }
                        }
                    }
                }
            }
        }
    </script>
    <style>
        html {
            scroll-behavior: smooth;
        }
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        .btn-hover:hover {
            transform: scale(1.05);
        }
        .section-title {
            position: relative;
            display: inline-block;
        }
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 3px;
            background-color: #e53e3e;
        }
        .achievement-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.875rem;
            font-weight: 500;
            margin: 2px;
        }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal-content {
            background-color: white;
            border-radius: 12px;
            max-width: 500px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
        }
        .language-selector {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
        }
        .lang-btn {
            background: white;
            border: 2px solid #e53e3e;
            color: #e53e3e;
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .lang-btn:hover {
            background: #e53e3e;
            color: white;
        }
        .lang-btn.active {
            background: #e53e3e;
            color: white;
        }
        @media (max-width: 640px) {
            .language-selector {
                top: 10px;
                right: 10px;
            }
            .lang-btn {
                padding: 6px 12px;
                font-size: 0.875rem;
            }
        }
    </style>
</head>
<body class="min-h-screen bg-gray-50 font-body text-gray-800">
    <!-- Языковой переключатель -->
    <div class="language-selector">
        <div class="flex gap-2">
            <button id="langRu" class="lang-btn active">RU</button>
            <button id="langUz" class="lang-btn">UZ</button>
        </div>
    </div>

    <!-- Навигация -->
