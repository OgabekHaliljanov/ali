                                    <span class="w-2 h-2 bg-accent rounded-full mr-2"></span>
                                    <span class="text-gray-700" data-lang-key="champion2Achievement4">Лучший нокаут года 2022</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Чемпион 3 -->
