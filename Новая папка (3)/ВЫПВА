        <!-- Секция видео -->
        <section id="videos" class="py-16 bg-white">
            <div class="container mx-auto px-4">
                <h2 class="text-3xl md:text-4xl font-heading font-bold text-center text-primary mb-12 section-title" data-lang-key="videosTitle">Видео с боями</h2>
                <p class="text-center text-gray-600 mb-8 max-w-2xl mx-auto" data-lang-key="videosDescription">Посмотрите лучшие моменты из выступлений наших спортсменов. Нажмите на кнопку ниже, чтобы увидеть больше видео.</p>
                
